---
import "../styles/global.css";
import App from "../components/App";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Descarga libros de O'Reilly Learning en PDF y EPUB." />
    <meta name="theme-color" content="#991b1b" />
    <title>Ryliox</title>
    <script is:inline>
      (() => {
        window.addEventListener("load", () => {
          const host = window.location.hostname;
          const isLocalHost = host === "localhost" || host === "127.0.0.1";
          if (!isLocalHost) {
            return;
          }

          const clearLegacyRuntime = async () => {
            try {
              if ("serviceWorker" in navigator) {
                const registrations = await navigator.serviceWorker.getRegistrations();
                const ownRegistrations = registrations.filter((registration) => {
                  const scriptUrl =
                    registration.active?.scriptURL ||
                    registration.waiting?.scriptURL ||
                    registration.installing?.scriptURL ||
                    "";
                  const normalized = scriptUrl.toLowerCase();
                  return normalized.includes("/service-worker.js") || normalized.includes("ryliox");
                });
                await Promise.all(ownRegistrations.map((registration) => registration.unregister()));
              }

              if ("caches" in window) {
                const cacheKeys = await caches.keys();
                const ownCacheKeys = cacheKeys.filter((cacheKey) =>
                  cacheKey.toLowerCase().startsWith("ryliox"),
                );
                await Promise.all(ownCacheKeys.map((cacheKey) => caches.delete(cacheKey)));
              }
            } catch (_error) {
              // Ignore cleanup failures in local environments.
            }
          };

          void clearLegacyRuntime();
        });
      })();
    </script>
  </head>
  <body>
    <div class="mx-auto flex min-h-screen w-full max-w-7xl flex-col gap-6 px-4 py-5 sm:px-6 sm:py-6 lg:px-8 lg:py-8">
      <header class="soft-rise panel-surface-strong relative overflow-hidden rounded-[1.75rem] px-6 py-6 sm:px-8 sm:py-7 lg:px-10 lg:py-8">
        <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_12%,rgba(220,38,38,0.12),transparent_42%),radial-gradient(circle_at_86%_0%,rgba(248,113,113,0.1),transparent_30%)]" aria-hidden="true"></div>
        <div class="pointer-events-none absolute -left-10 top-0 h-28 w-28 rounded-full bg-brand/10 blur-3xl" aria-hidden="true"></div>
        <div class="pointer-events-none absolute -right-10 top-6 h-28 w-28 rounded-full bg-brand-deep/10 blur-3xl" aria-hidden="true"></div>
        <div class="relative flex items-end justify-between">
          <h1 class="font-display text-4xl font-semibold tracking-tight text-ink sm:text-5xl lg:text-6xl">
            Ryliox
          </h1>
        </div>
      </header>
      <main class="min-w-0">
        <App client:load />
      </main>
      <footer class="pb-1 text-center text-xs text-slate-400 sm:pb-2">
        Ryliox &mdash; Solo para uso personal
      </footer>
    </div>
  </body>
</html>
