---
import "../styles/global.css";
import App from "../components/App";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Descarga libros de O'Reilly Learning en PDF y EPUB." />
    <meta name="theme-color" content="#dc2626" />
    <title>Ryliox — Descargador de libros O'Reilly</title>
    <script is:inline>
      (() => {
        window.addEventListener("load", () => {
          const host = window.location.hostname;
          const isLocalHost = host === "localhost" || host === "127.0.0.1";
          if (!isLocalHost) {
            return;
          }

          const clearLegacyRuntime = async () => {
            try {
              if ("serviceWorker" in navigator) {
                const registrations = await navigator.serviceWorker.getRegistrations();
                const ownRegistrations = registrations.filter((registration) => {
                  const scriptUrl =
                    registration.active?.scriptURL ||
                    registration.waiting?.scriptURL ||
                    registration.installing?.scriptURL ||
                    "";
                  const normalized = scriptUrl.toLowerCase();
                  return normalized.includes("/service-worker.js") || normalized.includes("ryliox");
                });
                await Promise.all(ownRegistrations.map((registration) => registration.unregister()));
              }

              if ("caches" in window) {
                const cacheKeys = await caches.keys();
                const ownCacheKeys = cacheKeys.filter((cacheKey) =>
                  cacheKey.toLowerCase().startsWith("ryliox"),
                );
                await Promise.all(ownCacheKeys.map((cacheKey) => caches.delete(cacheKey)));
              }
            } catch (_error) {
              // Ignore cleanup failures in local environments.
            }
          };

          void clearLegacyRuntime();
        });
      })();
    </script>
  </head>
  <body>
    <div class="mx-auto flex min-h-screen w-full max-w-6xl flex-col gap-6 px-4 py-8 sm:px-6 lg:px-8">
      <header class="soft-rise relative overflow-hidden rounded-2xl border border-brand/20 bg-white/90 px-8 py-6 shadow-panel backdrop-blur sm:px-12 sm:py-8">
        <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_12%,rgba(220,38,38,0.16),transparent_46%)]" aria-hidden="true"></div>
        <div class="pointer-events-none absolute -left-5 -top-6 h-20 w-20 rounded-full bg-brand/15 blur-2xl" aria-hidden="true"></div>
        <div class="pointer-events-none absolute -right-8 top-0 h-24 w-24 rounded-full bg-brand-deep/10 blur-2xl" aria-hidden="true"></div>
        <div class="relative">
          <h1 class="bg-gradient-to-r from-ink via-brand-deep to-brand bg-clip-text text-5xl font-bold leading-loose tracking-tight text-transparent sm:text-6xl lg:text-7xl">Ryliox</h1>
        </div>
      </header>
      <main>
        <App client:load />
      </main>
      <footer class="pb-2 text-center text-xs text-slate-400">
        Ryliox &mdash; Solo para uso personal
      </footer>
    </div>
  </body>
</html>
