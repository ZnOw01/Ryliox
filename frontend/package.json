{
  "name": "ryliox-frontend",
  "private": true,
  "version": "1.1.5",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "engines": {
    "node": "^22.12.0 || ^24.0.0"
  },
  "scripts": {
    "build": "astro build",
    "build:watch": "astro build --watch",
    "check": "astro check",
    "lint": "tsc --noEmit && prettier --check \"src/**/*.{ts,tsx,astro,css,json}\"",
    "lint:fix": "tsc --noEmit && prettier --write \"src/**/*.{ts,tsx,astro,css,json}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,astro,css,json}\"",
    "typecheck": "tsc --noEmit"
  },
  "overrides": {
    "volar-service-yaml": "0.0.70",
    "yaml-language-server": "1.21.0"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tailwindcss/vite": "^4.1.0",
    "@tanstack/react-query": "^5.90.21",
    "astro": "^5.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^2.7.3",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^15.7.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.0",
    "tw-animate-css": "^1.2.0",
    "zustand": "^5.0.11"
