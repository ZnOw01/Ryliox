# =============================================================================
# Ryliox Environment Configuration
# =============================================================================
# Copy this file to .env and customize values as needed.
# All variables are optional; defaults are shown below.
#
# Precedence (highest -> lowest):
#   1. Environment variables
#   2. .env file
#   3. Built-in defaults
# =============================================================================

# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# Base URL for O'Reilly Learning Platform
# Default: https://learning.oreilly.com
BASE_URL=https://learning.oreilly.com

# HTTP Request Configuration
# REQUEST_DELAY: Seconds between requests (>= 0.0)
# REQUEST_TIMEOUT: HTTP timeout in seconds (>= 1)
# REQUEST_RETRIES: Retry attempts on failure (>= 0)
# REQUEST_RETRY_BACKOFF: Seconds between retries (>= 0.0)
REQUEST_DELAY=0.5
REQUEST_TIMEOUT=30
REQUEST_RETRIES=2
REQUEST_RETRY_BACKOFF=0.5

# Paths (relative to repo root unless absolute)
# OUTPUT_DIR: Where exported books are saved
# DATA_DIR: Runtime state directory (queue DB, error logs)
# COOKIES_FILE: Session cookie storage
# SESSION_DB_FILE: Auth session database
# Default: ./output, ./data, {DATA_DIR}/cookies.json, {DATA_DIR}/session.sqlite3
OUTPUT_DIR=./output
DATA_DIR=./data
COOKIES_FILE=./data/cookies.json
SESSION_DB_FILE=./data/session.sqlite3

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server binding
# HOST: Interface to listen on (use 0.0.0.0 for Docker, 127.0.0.1 for local)
# PORT: Server port (1-65535)
HOST=127.0.0.1
PORT=8000

# =============================================================================
# SECURITY CONFIGURATION - OWASP COMPLIANCE
# =============================================================================

# Environment mode
# ENVIRONMENT: 'development' or 'production'
# In production: API docs are disabled, JSON logging enabled, HTTPS enforced
ENVIRONMENT=development

# HTTPS Redirect
# ENABLE_HTTPS_REDIRECT: Redirect HTTP to HTTPS in production
ENABLE_HTTPS_REDIRECT=false

# Security Headers (OWASP A05)
# ENABLE_SECURITY_HEADERS: Add security headers (CSP, X-Frame-Options, etc.)
ENABLE_SECURITY_HEADERS=true

# HSTS (HTTP Strict Transport Security) - OWASP A02
# ENABLE_HSTS: Enable HSTS header (only in production with TLS)
# WARNING: Once enabled, browsers will refuse HTTP connections
ENABLE_HSTS=false
HSTS_MAX_AGE=31536000

# Trusted Hosts (OWASP A05)
# ALLOWED_HOSTS: Comma-separated list of allowed hostnames in production
ALLOWED_HOSTS=localhost,127.0.0.1,::1

# Content Security Policy (OWASP A05)
# CSP_POLICY: Define allowed sources for scripts, styles, images, etc.
CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'none';

# Request Security Limits (OWASP A04, A05)
# MAX_REQUEST_SIZE_MB: Maximum request size in megabytes (>= 1)
MAX_REQUEST_SIZE_MB=10

# Request Timeout (OWASP A04 - Circuit Breaker)
# REQUEST_TIMEOUT_SECONDS: Maximum request processing time
REQUEST_TIMEOUT_SECONDS=60

# CORS Configuration (OWASP A05)
# CORS_ORIGINS: Comma-separated list of allowed origins
# Use '*' to allow all (development only)
# Examples: 'http://localhost:8000' or 'https://mydomain.com,https://app.mydomain.com'
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# =============================================================================
# RATE LIMITING (OWASP A04)
# =============================================================================

# Rate limiting protects against abuse and DoS attacks
# Applied to sensitive endpoints: /api/download, /api/cookies

# RATE_LIMIT_MAX_REQUESTS: Maximum requests per window per IP (>= 1)
RATE_LIMIT_MAX_REQUESTS=5

# RATE_LIMIT_WINDOW_SECONDS: Time window in seconds (>= 1)
RATE_LIMIT_WINDOW_SECONDS=60

# API Rate Limiting (broader scope)
# API_RATE_LIMIT_REQUESTS: Max requests per API window
API_RATE_LIMIT_REQUESTS=1000

# API_RATE_LIMIT_WINDOW: API window in seconds
API_RATE_LIMIT_WINDOW=3600

# =============================================================================
# SECRET MANAGEMENT (OWASP A02, A07)
# =============================================================================

# Secret Rotation
# SECRET_ROTATION_DAYS: Days between automatic secret rotation
SECRET_ROTATION_DAYS=90

# Master Password for Secret Encryption
# SECRET_MASTER_PASSWORD: Strong password for encrypting secrets at rest
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# WARNING: Store this in a secure vault, not in .env in production
# SECRET_MASTER_PASSWORD=your-secure-master-password-here

# Secrets Storage Paths
# SECRETS_DIR: Directory for secret storage
# SECRETS_FILE: Encrypted secrets file
SECRETS_DIR=./data/secrets
SECRETS_FILE=./data/secrets.json.enc

# =============================================================================
# AUDIT LOGGING (OWASP A09)
# =============================================================================

# Audit Log Configuration
# AUDIT_ENABLED: Enable comprehensive audit logging
AUDIT_ENABLED=true

# AUDIT_RETENTION_DAYS: Days to retain audit logs
AUDIT_RETENTION_DAYS=365

# Audit Log Paths
# AUDIT_LOG_DIR: Directory for audit logs
# AUDIT_LOG_FILE: Audit log file path
AUDIT_LOG_DIR=./data/audit
AUDIT_LOG_FILE=./data/audit.log

# =============================================================================
# CSRF PROTECTION (OWASP A08)
# =============================================================================

# CSRF Token Configuration
# CSRF_TOKEN_LENGTH: Length of CSRF tokens in bytes
CSRF_TOKEN_LENGTH=32

# CSRF_TOKEN_TTL: Token lifetime in seconds
CSRF_TOKEN_TTL=3600

# =============================================================================
# SESSION SECURITY (OWASP A07)
# =============================================================================

# Session Cookie Settings
# SESSION_COOKIE_SECURE: Require HTTPS for cookies (production only)
SESSION_COOKIE_SECURE=false

# SESSION_COOKIE_HTTPONLY: Prevent JavaScript access to cookies
SESSION_COOKIE_HTTPONLY=true

# SESSION_COOKIE_SAMESITE: SameSite cookie policy (Strict, Lax, None)
SESSION_COOKIE_SAMESITE=Lax

# SESSION_MAX_AGE: Session lifetime in seconds
SESSION_MAX_AGE=86400

# =============================================================================
# LOGGING & OBSERVABILITY
# =============================================================================

# Log Level
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG: Detailed logs (development)
# INFO: Standard logs (production default)
LOG_LEVEL=INFO

# Metrics
# ENABLE_METRICS: Enable Prometheus metrics at /api/metrics
# Requires prometheus-client to be installed (included in requirements.txt)
ENABLE_METRICS=true

# API Response Caching
# API_CACHE_MAX_AGE: Cache duration for API responses in seconds (>= 0)
# Cacheable endpoints: /api/status, /api/book/*, /api/chapters/*, /api/search
API_CACHE_MAX_AGE=60

# Static Files Caching
# STATIC_CACHE_MAX_AGE: Cache duration for static files in seconds (>= 0)
STATIC_CACHE_MAX_AGE=3600

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# In-memory LRU cache settings
# These control cache size and TTL for different data types

# Book Metadata Cache
# CACHE_MAXSIZE_BOOKS: Maximum entries (>= 1)
# CACHE_TTL_BOOKS: Time-to-live in seconds (>= 0, 0 = no expiry)
CACHE_MAXSIZE_BOOKS=256
CACHE_TTL_BOOKS=3600

# Chapter List Cache
CACHE_MAXSIZE_CHAPTERS=128
CACHE_TTL_CHAPTERS=1800

# Search Results Cache
CACHE_MAXSIZE_SEARCH=64
CACHE_TTL_SEARCH=300

# =============================================================================
# HTTP CLIENT HEADERS
# =============================================================================

# User Agent
# USER_AGENT: Override the HTTP User-Agent header
# If not set, uses fake-useragent (if enabled) or random fallback
# USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# Enable fake-useragent library for User-Agent rotation
# ENABLE_FAKE_USERAGENT: Use rotating User-Agent strings
ENABLE_FAKE_USERAGENT=false

# Accept Headers
# ACCEPT: Value for Accept header
ACCEPT=text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8

# ACCEPT_ENCODING: Value for Accept-Encoding header
ACCEPT_ENCODING=gzip, deflate

# ACCEPT_LANGUAGE: Value for Accept-Language header
ACCEPT_LANGUAGE=en-US,en;q=0.5

# Extra Headers
# HEADERS: JSON object with additional HTTP headers
# Note: Cannot override User-Agent, Accept, Accept-Encoding, or Accept-Language
# HEADERS={"X-Custom-Header": "value"}

# =============================================================================
# APPLICATION METADATA
# =============================================================================

# Application Version
# Used in metrics and health checks
APP_VERSION=1.0.0

# =============================================================================
# DEVELOPMENT / DEBUG
# =============================================================================

# Debug Mode (enable for detailed error pages and API docs in production)
# DEBUG=true

# =============================================================================
# PRODUCTION CHECKLIST - OWASP SECURITY
# =============================================================================
# Before deploying to production, ensure:
#
# [ ] ENVIRONMENT=production
# [ ] ENABLE_HTTPS_REDIRECT=true (if using HTTPS)
# [ ] ENABLE_HSTS=true (only after confirming HTTPS works)
# [ ] ENABLE_SECURITY_HEADERS=true
# [ ] ALLOWED_HOSTS set to your actual domains
# [ ] CORS_ORIGINS set to your actual domains (NOT '*')
# [ ] RATE_LIMIT_MAX_REQUESTS and RATE_LIMIT_WINDOW_SECONDS appropriate
# [ ] API_RATE_LIMIT_REQUESTS and API_RATE_LIMIT_WINDOW configured
# [ ] LOG_LEVEL=INFO (or WARNING)
# [ ] AUDIT_ENABLED=true
# [ ] AUDIT_RETENTION_DAYS set appropriately
# [ ] SECRET_MASTER_PASSWORD set (store in secure vault)
# [ ] SESSION_COOKIE_SECURE=true (only with HTTPS)
# [ ] SESSION_COOKIE_HTTPONLY=true
# [ ] SESSION_COOKIE_SAMESITE=Strict
# [ ] ENABLE_METRICS=true (for monitoring)
# [ ] BASE_URL is correct
# [ ] OUTPUT_DIR and DATA_DIR have correct permissions
# [ ] .env file is NOT committed to version control
# [ ] secrets/credentials are in environment variables, not .env
# [ ] Run: pip install safety && safety check
# [ ] Run: snyk test (if using Snyk)
#
# OWASP Security Best Practices Implemented:
# - A01: Access Control (RBAC, path traversal protection)
# - A02: Cryptographic Failures (secret encryption, HSTS)
# - A03: Injection Prevention (input validation, XSS protection)
# - A04: Insecure Design (rate limiting, circuit breakers)
# - A05: Security Misconfiguration (secure headers, HSTS)
# - A06: Vulnerable Components (dependency scanning with snyk)
# - A07: Auth Failures (secure session management, MFA prep)
# - A08: Data Integrity (CSRF tokens, integrity checks)
# - A09: Logging Failures (comprehensive audit logging)
# - A10: SSRF Protection (URL validation, IP blocking)
#
# Additional Security Features:
# - Content Security Policy (CSP)
# - Permissions Policy
# - Cross-Origin policies (COEP, COOP, CORP)
# - Trusted Host validation
# - Request size limits
# - Request timeout (circuit breaker)
# - Secret rotation
# - Immutable audit logs with integrity verification
# - Input sanitization and validation
# - Path traversal prevention
# - SSRF prevention with IP blacklist
#
# =============================================================================
