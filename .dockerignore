.git/
.gitignore
.gitattributes
.gitmodules
.github/
.gitkeep

# ==============================================================================
# Environment & Secrets (CRITICAL - NEVER INCLUDE IN BUILDS)
# ==============================================================================
.env
.env.*
!.env.example
!.env.template
secrets/
secrets.*
*.pem
*.key
*.crt
*.p12
*.pfx
*.der
*.priv
*.private
private.*
keyfile.*
credentials.*
*.credentials
.creds/

